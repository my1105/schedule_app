<div class="card">
  <% if @schedule.errors.any? %>
    <div class="errors">
      <ul>
        <% @schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<%= form_with model: @schedule do |f| %>

  <div>
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :start_at, "開始日" %>
    <%= f.date_field :start_at %>
  </div>

  <div>
    <%= f.label :end_at, "終了日" %>
    <%= f.date_field :end_at %>
  </div>

  <div>
    <%= f.label :all_day, "終日" %>
    <%= f.check_box :all_day %>
  </div>

  <div>
    <%= f.label :memo, "メモ" %>
    <%= f.text_area :memo %>
  </div>

  <div>
　　<%= f.submit @schedule.persisted? ? "予定を更新" : "予定を登録",class: "btn btn-primary" %>
  </div>

<% end %>
</div>